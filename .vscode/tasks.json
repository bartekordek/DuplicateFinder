    "version": "2.0.0",
    "tasks": [
        {
            "label": "[Windows][CMAKE][CREATE][NoTracy]",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-DCMAKE_POLICY_VERSION_MINIMUM=3.5",
                "-S",
                ".",
                "-B",
                "Build-Windows",
                "-DTRACY_ENABLE:BOOLEAN=OFF",
                "-DTRACY_ON_DEMAND:BOOLEAN=OFF"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            },
            "dependsOn": "[Windows][CMAKE][CREATE DIR]",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
